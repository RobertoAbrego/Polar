@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var userEmail = Context.Session.GetString("UserEmail");
    var userName = Context.Session.GetString("UserName") ?? "Usuario";
    var userPhoto = Context.Session.GetString("UserPhoto");

    var initial = userName.Substring(0,1).ToUpper();
}

<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Polar</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

</head>

<body class="d-flex flex-column min-vh-100">

<header>

<nav class="navbar navbar-expand-lg navbar-dark navbar-polar">

<div class="container">

    <a class="navbar-brand brand-polar d-flex align-items-center gap-2"
       asp-controller="Home"
       asp-action="Index">

       <img src="~/img/logo.png" height="40" />

    </a>

    <button class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbar">

        <span class="navbar-toggler-icon"></span>

    </button>

    <div class="collapse navbar-collapse" id="navbar">

        <ul class="navbar-nav me-auto">

            <li class="nav-item">
                <a class="nav-link nav-polar-link"
                   asp-controller="Home"
                   asp-action="Index">

                    Inicio

                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link nav-polar-link"
                   asp-controller="Home"
                   asp-action="Privacy">

                    Privacidad

                </a>
            </li>

            @if(userEmail != null)
            {
                <li class="nav-item">
                    <a class="nav-link nav-polar-link"
                       asp-controller="Feed"
                       asp-action="Index">

                        Feed

                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link nav-polar-link"
                       asp-controller="Evidencia"
                       asp-action="Crear">

                        Subir evidencia

                    </a>
                </li>
            }

        </ul>

        <ul class="navbar-nav">

            @if(userEmail == null)
            {
                <li class="nav-item me-2">
                    <a class="btn btn-outline-light"
                       asp-controller="Auth"
                       asp-action="Login">

                        Iniciar sesión

                    </a>
                </li>

                <li class="nav-item">
                    <a class="btn btn-success"
                       asp-controller="Auth"
                       asp-action="Register">

                        Crear cuenta

                    </a>
                </li>
            }
            else
            {
                <li class="nav-item dropdown">

                    <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                       href="#"
                       data-bs-toggle="dropdown">

                        @if(!string.IsNullOrWhiteSpace(userPhoto))
                        {
                            <img src="@userPhoto"
                                 class="user-avatar" />
                        }
                        else
                        {
                            <div class="user-fallback">
                                @initial
                            </div>
                        }

                        <span class="text-white">
                            @userName
                        </span>

                    </a>

                    <ul class="dropdown-menu dropdown-menu-end">

                        <li>
                            <span class="dropdown-item-text fw-bold">
                                @userName
                            </span>
                        </li>

                        <li><hr class="dropdown-divider" /></li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Profile"
                               asp-action="Settings">

                                Configuración

                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item text-danger"
                               asp-controller="Auth"
                               asp-action="Logout">

                                Cerrar sesión

                            </a>
                        </li>

                    </ul>

                </li>
            }

        </ul>

    </div>

</div>

</nav>

</header>

<main class="container py-4 flex-grow-1">

    @RenderBody()

</main>

<footer class="footer-polar py-4 mt-auto">

    <div class="container text-center">

        <div class="fw-bold mb-1">
            Polar
        </div>

        <div class="text-polar-muted">
            Plataforma ecológica enfocada en hábitos sostenibles 🌎
        </div>

        <small class="text-polar-muted">
            © 2026 Polar
        </small>

    </div>

</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>