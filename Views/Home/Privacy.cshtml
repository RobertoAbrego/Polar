@{
    ViewData["Title"] = "Privacidad";
}

<div class="container py-5">

    <!-- TÍTULO -->
    <div class="text-center mb-5">
        <h1 class="fw-bold display-5">Política de Privacidad</h1>
        <p class="text-muted">
            En Polar valoramos la privacidad y seguridad de nuestros usuarios.
        </p>
    </div>

    <!-- INTRO -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <h3 class="fw-bold mb-3">¿Qué es Polar?</h3>

            <p>
                Polar es una plataforma ecológica y social enfocada en fomentar
                la conciencia ambiental mediante publicaciones, misiones y
                participación comunitaria.
            </p>

            <p class="mb-0">
                Al utilizar nuestra plataforma, aceptas las prácticas descritas
                en esta política de privacidad.
            </p>
        </div>
    </div>

    <!-- DATOS -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">

            <h3 class="fw-bold mb-3">Información que recopilamos</h3>

            <ul class="mb-0">
                <li>Nombre de usuario</li>
                <li>Correo electrónico</li>
                <li>Publicaciones y comentarios realizados</li>
                <li>Evidencias subidas a las misiones</li>
                <li>Información básica de sesión</li>
            </ul>

        </div>
    </div>

    <!-- USO -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">

            <h3 class="fw-bold mb-3">Uso de la información</h3>

            <p>
                La información recopilada es utilizada únicamente para:
            </p>

            <ul class="mb-0">
                <li>Gestionar cuentas de usuario</li>
                <li>Mostrar publicaciones y contenido social</li>
                <li>Validar participación en misiones ecológicas</li>
                <li>Mejorar la experiencia dentro de la plataforma</li>
                <li>Mantener la seguridad del sistema</li>
            </ul>

        </div>
    </div>

    <!-- SEGURIDAD -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">

            <h3 class="fw-bold mb-3">Seguridad</h3>

            <p>
                Polar implementa medidas de seguridad para proteger la
                información de los usuarios, incluyendo cifrado de contraseñas
                y control de sesiones.
            </p>

            <p class="mb-0">
                No compartimos información personal con terceros sin autorización.
            </p>

        </div>
    </div>

    <!-- CONTENIDO -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">

            <h3 class="fw-bold mb-3">Contenido publicado</h3>

            <p>
                Los usuarios son responsables del contenido que publican dentro
                de la plataforma.
            </p>

            <p class="mb-0">
                Polar se reserva el derecho de eliminar contenido ofensivo,
                inapropiado o que incumpla las normas comunitarias.
            </p>

        </div>
    </div>

    <!-- FINAL -->
    <div class="text-center mt-5">
        <p class="text-muted mb-1">
            Última actualización: Mayo 2026
        </p>

        <small class="text-secondary">
            © 2026 Polar - Plataforma ecológica y social
        </small>
    </div>

</div>