@{
    ViewData["Title"] = "Privacidad";
}

<div class="privacy-wrapper">

    <!-- HERO -->
    <div class="privacy-hero">

        <span class="privacy-badge">
            Seguridad y transparencia
        </span>

        <h1 class="privacy-title">
            Política de Privacidad
        </h1>

        <p class="privacy-subtitle">
            En Polar protegemos la información de nuestros usuarios y promovemos
            una experiencia segura, transparente y enfocada en la comunidad.
        </p>

    </div>

    <!-- GRID -->
    <div class="privacy-grid">

        <div class="privacy-card">

            <div class="privacy-icon">
                🌎
            </div>

            <h3>
                ¿Qué es Polar?
            </h3>

            <p>
                Polar es una plataforma ecológica y social diseñada para impulsar
                hábitos sostenibles mediante retos, publicaciones y participación comunitaria.
            </p>

        </div>

        <div class="privacy-card">

            <div class="privacy-icon">
                🔐
            </div>

            <h3>
                Información recopilada
            </h3>

            <ul>
                <li>Nombre de usuario</li>
                <li>Correo electrónico</li>
                <li>Comentarios y publicaciones</li>
                <li>Evidencias ecológicas</li>
                <li>Información básica de sesión</li>
            </ul>

        </div>

        <div class="privacy-card">

            <div class="privacy-icon">
                ⚡
            </div>

            <h3>
                Uso de la información
            </h3>

            <ul>
                <li>Gestionar cuentas</li>
                <li>Mostrar contenido social</li>
                <li>Validar participación en misiones</li>
                <li>Mejorar experiencia del usuario</li>
                <li>Proteger la plataforma</li>
            </ul>

        </div>

        <div class="privacy-card">

            <div class="privacy-icon">
                🛡
            </div>

            <h3>
                Seguridad
            </h3>

            <p>
                Polar implementa mecanismos de protección como cifrado de contraseñas,
                validación de sesiones y control básico de acceso.
            </p>

        </div>

        <div class="privacy-card">

            <div class="privacy-icon">
                💬
            </div>

            <h3>
                Contenido publicado
            </h3>

            <p>
                Cada usuario es responsable del contenido que comparte dentro de la plataforma.
                Polar puede eliminar publicaciones ofensivas o inapropiadas.
            </p>

        </div>

        <div class="privacy-card">

            <div class="privacy-icon">
                📅
            </div>

            <h3>
                Última actualización
            </h3>

            <p class="mb-0">
                Mayo 2026
            </p>

        </div>

    </div>

    <!-- FOOTER -->
    <div class="privacy-footer">

        © 2026 Polar · Plataforma ecológica y social

    </div>

</div>