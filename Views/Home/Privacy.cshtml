@{
    ViewData["Title"] = "Privacidad";
}

<div class="privacy-wrapper">

    <!-- HERO -->
    <div class="privacy-hero">

        <span class="privacy-badge">
            Seguridad y transparencia
        </span>

        <h1 class="privacy-title">
            Política de Privacidad
        </h1>

        <p class="privacy-subtitle">
            En Polar protegemos la información de nuestros usuarios y promovemos
            una experiencia segura, transparente y enfocada en la comunidad.
        </p>

    </div>

    <!-- GRID -->
    <div class="privacy-grid">

        <div class="privacy-card">

            <div class="privacy-icon">
                🌎
            </div>

            <h3>
                ¿Qué es Polar?
            </h3>

            <p>
                Polar es una plataforma ecológica y social diseñada para impulsar
                hábitos sostenibles mediante retos, publicaciones y participación comunitaria.
            </p>

        </div>

        <div class="privacy-card">

            <div class="privacy-icon">
                🔐
            </div>

            <h3>
                Información recopilada
            </h3>

            <ul>
                <li>Nombre de usuario</li>
                <li>Correo electrónico</li>
                <li>Comentarios y publicaciones</li>
                <li>Evidencias ecológicas</li>
                <li>Información básica de sesión</li>
            </ul>

        </div>

        <div class="privacy-card">

            <div class="privacy-icon">
                ⚡
            </div>

            <h3>
                Uso de la información
            </h3>

            <ul>
                <li>Gestionar cuentas</li>
                <li>Mostrar contenido social</li>
                <li>Validar participación en misiones</li>
                <li>Mejorar experiencia del usuario</li>
                <li>Proteger la plataforma</li>
            </ul>

        </div>

        <div class="privacy-card">

            <div class="privacy-icon">
                🛡
            </div>

            <h3>
                Seguridad
            </h3>

            <p>
                Polar implementa mecanismos de protección como cifrado de contraseñas,
                validación de sesiones y control básico de acceso.
            </p>

        </div>

        <div class="privacy-card">

            <div class="privacy-icon">
                💬
            </div>

            <h3>
                Contenido publicado
            </h3>

            <p>
                Cada usuario es responsable del contenido que comparte dentro de la plataforma.
                Polar puede eliminar publicaciones ofensivas o inapropiadas.
            </p>

        </div>

        <div class="privacy-card">

            <div class="privacy-icon">
                📅
            </div>

            <h3>
                Última actualización
            </h3>

            <p class="mb-0">
                Mayo 2026
            </p>

        </div>

    </div>

    <!-- FOOTER -->
    <div class="privacy-footer">

        © 2026 Polar · Plataforma ecológica y social

    </div>

</div>

<style>

.privacy-wrapper{
    max-width:1150px;
    margin:auto;
    padding:2rem 1rem 5rem;
}

.privacy-hero{
    text-align:center;
    margin-bottom:4rem;
}

.privacy-badge{
    display:inline-block;
    background:#dcfce7;
    color:#166534;
    padding:.6rem 1rem;
    border-radius:999px;
    font-weight:700;
    margin-bottom:1.2rem;
}

.privacy-title{
    font-size:3rem;
    font-weight:900;
    color:#163020;
    margin-bottom:1rem;
}

.privacy-subtitle{
    max-width:750px;
    margin:auto;
    color:#6b7280;
    line-height:1.8;
    font-size:1.08rem;
}

.privacy-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:1.5rem;
}

.privacy-card{
    background:white;
    border-radius:28px;
    padding:2rem;
    box-shadow:0 10px 30px rgba(0,0,0,.06);
    transition:.25s ease;
    border:1px solid rgba(0,0,0,.04);
}

.privacy-card:hover{
    transform:translateY(-6px);
}

.privacy-card h3{
    font-weight:800;
    margin-bottom:1rem;
    color:#163020;
}

.privacy-card p,
.privacy-card li{
    color:#4b5563;
    line-height:1.7;
}

.privacy-card ul{
    padding-left:1.2rem;
    margin-bottom:0;
}

.privacy-icon{
    width:65px;
    height:65px;
    border-radius:18px;
    background:linear-gradient(135deg,#22c55e,#16a34a);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:1.6rem;
    margin-bottom:1.5rem;
    box-shadow:0 8px 18px rgba(34,197,94,.25);
}

.privacy-footer{
    text-align:center;
    margin-top:4rem;
    color:#6b7280;
    font-weight:600;
}

</style>