@model List<Polar.Models.FeedPost>

@{
    ViewData["Title"] = "Feed";
}

<div class="feed-container">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>
            <span class="badge-polar mb-2 d-inline-block">
                Comunidad
            </span>

            <h1 class="feed-title mb-1">
                🌍 Feed ecológico
            </h1>

            <p class="feed-subtitle mb-0">
                Descubre acciones reales realizadas por la comunidad Polar.
            </p>
        </div>

        <a asp-controller="Evidencia"
           asp-action="Crear"
           class="btn btn-success btn-lg rounded-pill px-4 shadow-sm">

            📸 Compartir evidencia

        </a>

    </div>

                        @foreach (var item in Model)
                        {
                            <div class="feed-card">

                                <!-- HEADER -->
                                <div class="feed-header">

                                    <div class="d-flex align-items-center gap-3">

                                        @if(!string.IsNullOrWhiteSpace(item.FotoPerfil))
                    {
                        <img src="@item.FotoPerfil"
                            class="user-avatar" />
                    }
                    else
                    {
                        <div class="user-fallback">

                            @(string.IsNullOrEmpty(item.Nombre)
                                ? "U"
                                : item.Nombre.Substring(0,1).ToUpper())

                        </div>
                    }

                    <div>

                        <div class="fw-bold fs-5">
                            @item.Nombre
                        </div>

                        <small class="text-muted">
                            @item.Fecha
                        </small>

                    </div>

                </div>

                <div class="d-flex gap-2 align-items-center">

                    <span class="badge bg-success px-3 py-2">
                        +@item.Puntos pts
                    </span>

                    @if (item.EsMia)
                    {
                        <form asp-controller="Feed"
                              asp-action="Eliminar"
                              method="post">

                            <input type="hidden"
                                   name="id"
                                   value="@item.EvidenciaId" />

                            <button class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                🗑 Eliminar
                            </button>

                        </form>
                    }

                </div>

            </div>

            <!-- INFO -->
            <div class="feed-body">

                <div class="mb-3">

                    <span class="badge bg-dark px-3 py-2 mb-3">
                        @item.Tipo
                    </span>

                    <h3 class="fw-bold mb-3">
                        🌱 @item.Titulo
                    </h3>

                    @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                    {
                        <div class="feed-description">

                            @item.Descripcion

                        </div>
                    }

                </div>

                <!-- IMAGEN -->
                <div class="feed-image-wrapper">

                    <img src="@item.Imagen"
                         class="feed-image" />

                </div>

                <!-- COMENTARIOS -->
                <div class="mt-4">

                    <h5 class="fw-bold mb-3">
                        💬 Comentarios
                    </h5>

                    @if (item.Comentarios != null && item.Comentarios.Count > 0)
                    {
                        @foreach (var c in item.Comentarios)
                        {
                            <div class="comment-box">

                                <div class="d-flex justify-content-between align-items-center mb-2">

                                    <strong>
                                        @c.Nombre
                                    </strong>

                                    <small class="text-muted">
                                        @c.Fecha
                                    </small>

                                </div>

                                <p class="mb-0">
                                    @c.Contenido
                                </p>

                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-comments">
                            Aún no hay comentarios.
                        </div>
                    }

                </div>

                <!-- FORM -->
                <form asp-controller="Comentario"
                      asp-action="Crear"
                      method="post"
                      class="mt-4">

                    <input type="hidden"
                           name="publicacionId"
                           value="@item.EvidenciaId" />

                    <div class="input-group">

                        <input type="text"
                               name="contenido"
                               class="form-control comment-input"
                               placeholder="Escribe un comentario..."
                               required />

                        <button class="btn btn-success px-4">
                            Comentar
                        </button>

                    </div>

                </form>

            </div>

        </div>
    }

</div>
