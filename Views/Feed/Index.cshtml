@model List<Polar.Models.FeedPost>


<h2 class="mb-4">🌍 Feed de evidencias</h2>

@foreach (var item in Model)
{
    <div class="card mb-4 shadow-sm border-0">

        <!-- HEADER -->
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center">

                <div>
                    <h5 class="mb-0 fw-bold">
                        @item.Nombre
                    </h5>

                    <small class="text-muted">
                        @item.Fecha
                    </small>
                </div>

                @if (item.EsMia)
                {
                    <form asp-controller="Feed"
                          asp-action="Eliminar"
                          method="post">

                        <input type="hidden"
                               name="id"
                               value="@item.EvidenciaId" />

                        <button class="btn btn-sm btn-danger">
                            Eliminar
                        </button>

                    </form>
                }

            </div>

            <!-- INFO -->
            <div class="mt-3">

                <h4 class="fw-bold">
                    @item.Titulo
                </h4>

                <span class="badge bg-success">
                    @item.Tipo
                </span>

                <span class="badge bg-dark">
                    +@item.Puntos puntos
                </span>

            </div>

            <!-- IMAGEN -->
            <div class="mt-3">

                <img src="@item.Imagen"
                     class="img-fluid rounded shadow-sm w-100"
                     style="max-height:500px; object-fit:cover;" />

            </div>

            <!-- COMENTARIOS -->
            <div class="mt-4">

                <h6 class="fw-bold mb-3">
                    Comentarios
                </h6>

                @if (item.Comentarios != null && item.Comentarios.Count > 0)
                {
                    @foreach (var c in item.Comentarios)
                    {
                        <div class="border rounded p-2 mb-2 bg-light">

                            <strong>@c.Nombre</strong>

                            <small class="text-muted ms-2">
                                @c.Fecha
                            </small>

                            <p class="mb-0 mt-1">
                                @c.Contenido
                            </p>

                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">
                        No hay comentarios aún.
                    </p>
                }

            </div>

            <!-- AGREGAR COMENTARIO -->
            <form asp-controller="Comentario"
                  asp-action="Crear"
                  method="post"
                  class="mt-3">

                <input type="hidden"
                       name="publicacionId"
                       value="@item.EvidenciaId" />

                <div class="input-group">

                    <input type="text"
                           name="contenido"
                           class="form-control"
                           placeholder="Escribe un comentario..."
                           required />

                    <button class="btn btn-success">
                        Comentar
                    </button>

                </div>

            </form>

        </div>
    </div>
}